Algoritmo Lecc16_Act1_Inci1
	Definir n Como Entero
	Definir estuche Como Caracter
	Dimensionar estuche[8]
	estuche[8] = "Amarillo"
	estuche[7] = "Naranja"
	estuche[6] = "Rojo"
	estuche[5] = "Morado"
	estuche[4] = "Azul"
	estuche[3] = "Verde"
	estuche[2] = "Marrón"
	estuche[1] = "Negro"
	Escribir Sin Saltar " Dame un numero de casilla: "
